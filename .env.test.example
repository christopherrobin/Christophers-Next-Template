# PostgreSQL connection string for the test database.
# Playwright globalSetup runs `prisma migrate deploy` against this URL and
# truncates the User table before the suite runs. Point this at a dedicated
# test database — never your production or local-dev database.
DATABASE_TEST_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE_TEST

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# NextAuth.js canonical URL (required in production)
NEXTAUTH_URL=http://localhost:3000
