{
  "name": "christophers-next-template",
  "version": "1.0.0",
  "description": "A Next.js template with TypeScript, Tailwind CSS, Prisma, and NextAuth.js.",
  "author": "Christopher Reynolds",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "yarn run lint:fix && yarn run format:fix && prettier --write .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint --cache --max-warnings=0 \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --cache --fix \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\"",
    "nuke": "rm -rf node_modules && yarn install && yarn run build",
    "prebuild": "prisma generate",
    "predev": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "dotenv -e .env.test -- playwright test"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "prisma": "^6.19.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/christopherrobin/Christophers-Next-Template.git"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
